# =========================================================
# Backend runtime
# =========================================================
# 실행 환경 이름
APP_ENV=development

# 애플리케이션 DB 연결 문자열
# 로컬 기본값은 sqlite, 운영에서는 Supabase Postgres URL 사용
DATABASE_URL=sqlite:///./local_devops.db

# 프론트엔드 앱 주소
# Instagram OAuth callback 후 이 주소로 다시 이동
FRONTEND_APP_URL=http://localhost:3000


# =========================================================
# Internal security
# =========================================================
# 워커 엔드포인트(/internal/jobs/publish-due) 호출용 내부 토큰
INTERNAL_JOB_TOKEN=change-me

# Instagram OAuth state 서명용 비밀값
STATE_SECRET=change-me


# =========================================================
# Instagram integration
# =========================================================
# Meta App / Instagram Login 설정값
# 주의: 사용자별 OAuth access token / refresh token 은 env에 두지 않음
# 채널 연결 후 DB(social_accounts)에 사용자별로 저장
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Meta App에 등록한 redirect URI와 한 글자까지 동일해야 함
INSTAGRAM_REDIRECT_URI=http://localhost:8000/integrations/instagram/callback

# 요청할 Instagram 권한 목록
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish


# =========================================================
# Supabase Auth
# =========================================================
# Supabase 사용자 세션 검증용 값
# 이것도 사용자 채널 OAuth 토큰이 아니라, 앱 사용자 로그인 검증용 공개 설정
# 비워두면 backend는 개발용 헤더 인증으로 동작 가능
SUPABASE_URL=
SUPABASE_ANON_KEY=


# =========================================================
# Local development toggles
# =========================================================
# true면 Authorization 헤더 없이도 x-dev-user-* 헤더로 로그인 흉내 가능
ENABLE_DEV_AUTH=true

# true면 실제 Instagram publish 대신 mock 응답 반환
MOCK_INSTAGRAM_PUBLISH=true
