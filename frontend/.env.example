# =========================================================
# Frontend API target
# =========================================================
# Next.js 앱이 호출할 FastAPI backend 주소
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000


# =========================================================
# Supabase browser auth
# =========================================================
# 값이 채워지면 브라우저에서 Supabase 로그인 사용
# 비워두면 개발용 헤더 모드로 backend에 요청
# 주의: 이것은 사용자 채널 OAuth 토큰이 아니라 앱 사용자 로그인용 설정
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# =========================================================
# Local development identity
# =========================================================
# Supabase 없이 로컬에서 테스트할 때 사용할 개발용 사용자
NEXT_PUBLIC_DEV_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEV_USER_EMAIL=dev@local.test
